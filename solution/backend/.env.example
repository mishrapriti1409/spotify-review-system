# Backend environment variables
# Set these in Railway / Render / Fly.io dashboard — do NOT commit real values

GROQ_API_KEY=your_groq_api_key_here

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Optional
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=

# URL of your deployed Vercel frontend (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Path where persistent data is stored (use Railway/Render disk mount path)
DATA_DIR=/app/data
